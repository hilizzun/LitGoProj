<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Header -->
    <TextView
        android:id="@+id/titleTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/my_collection"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_margin="16dp" />

    <!-- Search Bar -->
    <LinearLayout
        android:id="@+id/searchLayout"
        android:layout_width="0dp"
        android:layout_height="45dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_search"
        android:padding="12dp"
        app:layout_constraintTop_toBottomOf="@id/titleTextView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp">

        <EditText
            android:id="@+id/searchEditText"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:hint="@string/search_hint"
            android:background="@null"
            android:textSize="14sp"
            android:inputType="text"
            android:imeOptions="actionSearch" />

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_search"
            android:layout_marginEnd="8dp" />

        <ImageView
            android:id="@+id/filterButton"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_filter"/>
    </LinearLayout>

    <!-- Filter Tabs -->
    <HorizontalScrollView
        android:id="@+id/tabsScrollView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/searchLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <Button
                android:id="@+id/tabAll"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:minWidth="64dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/tab_all"
                android:backgroundTint="@color/primary"
                android:textSize="12sp"
                android:fontFamily="@font/nunito_regular" />

            <Button
                android:id="@+id/tabReading"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:minWidth="64dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/tab_reading"
                android:backgroundTint="@color/surface"
                android:textColor="@color/text_primary"
                android:layout_marginStart="6dp"
                android:textSize="12sp"
                android:fontFamily="@font/nunito_regular" />

            <Button
                android:id="@+id/tabRead"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:minWidth="64dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/tab_read"
                android:backgroundTint="@color/surface"
                android:textColor="@color/text_primary"
                android:layout_marginStart="6dp"
                android:textSize="12sp"
                android:fontFamily="@font/nunito_regular" />

            <Button
                android:id="@+id/tabPlanned"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:minWidth="64dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/tab_planned"
                android:backgroundTint="@color/surface"
                android:textColor="@color/text_primary"
                android:layout_marginStart="6dp"
                android:textSize="12sp"
                android:fontFamily="@font/nunito_regular" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Book List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/booksRecyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/tabsScrollView"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        android:paddingBottom="88dp" />

    <!-- FAB для добавления книги -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAdd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@android:drawable/ic_input_add"
        android:contentDescription="@string/new_book"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_margin="16dp"
        app:tint="@android:color/white"
        android:backgroundTint="@color/primary" />

</androidx.constraintlayout.widget.ConstraintLayout>