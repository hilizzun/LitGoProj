<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <!-- Book Cover -->
    <ImageView
        android:id="@+id/noteCoverImageView"
        android:layout_width="57dp"
        android:layout_height="77dp"
        android:scaleType="centerCrop"
        android:background="@drawable/bg_book_cover"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Note Info Container -->
    <LinearLayout
        android:id="@+id/noteInfoContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="16dp"
        app:layout_constraintStart_toEndOf="@id/noteCoverImageView"
        app:layout_constraintEnd_toStartOf="@id/btnDelete"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="7.09.2023 в 12:03"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#203D43"
            android:fontFamily="@font/nunito_bold" />

        <TextView
            android:id="@+id/tvBookName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Мастер и Маргарита"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#203D43"
            android:fontFamily="@font/nunito_bold"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvPages"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="20 страниц"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#ffaf1a"
            android:fontFamily="@font/nunito_extrabold"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <!-- Delete Button -->
    <ImageView
        android:id="@+id/btnDelete"
        android:layout_width="17dp"
        android:layout_height="17dp"
        android:src="@drawable/ic_delete"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Divider -->
    <View
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:background="#E0E0E0"
        app:layout_constraintTop_toBottomOf="@id/noteInfoContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>